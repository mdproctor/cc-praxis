#!/bin/bash
# pre-push hook: mechanical squash candidate check
# Installed by git-squash skill. Blocks obvious policy violations before push.
# Run /git-squash for the full AI-assisted analysis.
# Bypass with: git push --no-verify

remote="$1"

# Coarse pattern filter — only clear-cut noise that the AI analysis would always SQUASH.
# fix(ci): is intentionally excluded: a single fix(ci): commit can be substantial
# (e.g. aligning with upstream SNAPSHOT API changes). CI arc detection runs in the
# full /git-squash analysis.
SQUASH_PATTERNS='(^chore: (remove dead|apply spotless|fix formatting|remove unused|pin |add jandex)|^docs\([^)]+\): (align|fix wording|add missing)|^docs: fix stale|^fix\(test\):|^ci: (retrigger|trigger CI|use GH_PAT|standardise|add workflow)|^chore: (retroactive issue|pin )|^Revert ")'

total=0
candidates=0

while read local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  # Block pushes to main/master when local has diverged from origin.
  # Catches stale-main merges that create local/remote divergence.
  branch_name=$(echo "$remote_ref" | sed 's|refs/heads/||')
  if echo "$remote_ref" | grep -qE "refs/heads/(main|master)$"; then
    git fetch "$remote" "$branch_name" --quiet 2>/dev/null
    behind=$(git rev-list HEAD.."$remote/$branch_name" --count 2>/dev/null || echo 0)
    if [ "$behind" -gt 0 ]; then
      echo ""
      echo "❌ Local $branch_name is $behind commits behind $remote/$branch_name."
      echo "   Run: git pull --rebase origin $branch_name"
      echo "   Then push again."
      exit 1
    fi
  fi

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — compare to default branch
    base=$(git rev-parse --verify origin/main 2>/dev/null || git rev-parse --verify origin/master 2>/dev/null || echo "")
    [ -z "$base" ] && continue
    range="$base..$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  total=$(git log --oneline "$range" 2>/dev/null | wc -l | tr -d ' ')
  [ "$total" -eq 0 ] && continue

  candidates=$(git log --oneline "$range" 2>/dev/null | grep -cE "$SQUASH_PATTERNS" || true)

  if [ "$candidates" -gt 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  Pre-push: squash candidates detected                    ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    printf "║  Commits in push:    %-36s║\n" "$total"
    printf "║  Squash candidates:  %-36s║\n" "$candidates"
    echo "║                                                          ║"
    echo "║  Run /git-squash to clean history, or --no-verify        ║"
    echo "║  if history is already clean.                            ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
done

exit 0
